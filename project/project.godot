; Blackout Protocol: Steel Echo — Godot/Jolt vertical slice
config_version=5

[application]
config/name="Blackout Protocol: Steel Echo"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/icon.svg"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
anti_aliasing/quality/msaa_3d=0
anti_aliasing/quality/screen_space_aa=0
occlusion_culling/use_occlusion_culling=true
environment/defaults/default_clear_color=Color(0.018, 0.024, 0.032, 1)
textures/default_filters/use_nearest_mipmap_filter=false

[physics]
3d/physics_engine="Jolt Physics"
common/physics_ticks_per_second=60
common/physics_interpolation=true

[physics_jolt_physics_3d]
simulation/allow_sleep=true
simulation/velocity_steps=8
simulation/position_steps=2
limits/temporary_memory_buffer_size=16777216

[audio]
driver/enable_input=false
default_bus_layout="res://default_bus_layout.tres"
